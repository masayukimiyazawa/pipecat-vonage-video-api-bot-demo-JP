# LM Studio (local LLM)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_MODEL=

# STT (local Whisper via faster-whisper)
STT_LANGUAGE=ja

# Audio settings
VONAGE_AUDIO_RATE=16000

# TTS (pyopenjtalk — Japanese HTS engine, no model download needed)
# See tts_piper_plus.py for speed/half_tone settings

# --- Vonage Video API (required for demo) ---
VONAGE_APPLICATION_ID=your_application_id
VONAGE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"
# VONAGE_PRIVATE_KEY=/path/to/private.key

# Optional: override public WebSocket URL (auto-detected via ngrok otherwise)
# WS_URI=wss://your-ngrok-domain/ws
